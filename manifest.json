{
  "manifest_version": 3,
  "name": "Indicadores MX",
  "version": "1.0",
  "description": "Tu dashboard financiero: indicadores oficiales de Banxico e INEGI, mercados globales en tiempo real y alertas de volatilidad.",
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "onboarding.html",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.banxico.org.mx/*",
    "https://www.inegi.org.mx/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://www.myfxbook.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}